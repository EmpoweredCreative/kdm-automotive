# --- Production (Forge / static build): quote form ---
# Free key at https://web3forms.com — add to Forge Site → Environment so it is
# present when `npm run build` runs (Vite embeds VITE_* at build time).
VITE_WEB3FORMS_ACCESS_KEY=

# --- Local dev only: SendGrid API behind Vite proxy (`npm run dev`) ---
PORT=8787
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_TO_EMAIL=
SENDGRID_SUBJECT=New KDM Quote Request
SENDGRID_SENDER_NAME=KDM Automotive, LLC

# Optional: bind Express API (only used when Web3 key is unset + local dev)
# BIND_HOST=127.0.0.1
