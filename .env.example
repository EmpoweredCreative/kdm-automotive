# Port OUR Node app listens on (localhost only). Nginx proxies /api → here.
# SendGrid has nothing to do with this — they are api.sendgrid.com over HTTPS.
PORT=8787

# SendGrid — emails quote requests to your inbox (SENDGRID_TO_EMAIL)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_TO_EMAIL=
SENDGRID_SUBJECT=New KDM Quote Request
SENDGRID_SENDER_NAME=KDM Automotive, LLC

# Production only: bind API to localhost (nginx proxies to it)
# BIND_HOST=127.0.0.1
